# Copy to .env on your DigitalOcean droplet before deploy:
#   cp .env.production.example .env

# Public URL of your app (used for CORS if needed)
CORS_ORIGINS=http://YOUR_DROPLET_IP,https://your-domain.com

# Port exposed on the droplet (80 = standard HTTP)
HTTP_PORT=80

# Neo4j credentials — change in production!
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-to-a-strong-password
NEO4J_DATABASE=neo4j
NEO4J_ENABLED=true
